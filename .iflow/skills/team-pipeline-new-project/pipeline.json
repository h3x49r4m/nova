{"name": "new-project", "version": "1.0.0", "description": "Full pipeline for new projects from scratch", "stages": [{"name": "Requirements Gathering", "role": "client", "order": 1, "required": true, "skill": "client", "prompt_template": "Gather requirements for new project: {feature_name}"}, {"name": "Project Specification", "role": "product-manager", "order": 2, "required": true, "dependencies": [1], "skill": "product-manager", "prompt_template": "Create project specification for: {feature_name}"}, {"name": "Architecture Design", "role": "tech-lead", "order": 3, "required": true, "dependencies": [2], "skill": "tech-lead", "prompt_template": "Design architecture for project: {feature_name}"}, {"name": "Tech Stack Selection", "role": "tech-lead", "order": 4, "required": true, "dependencies": [3], "skill": "tech-lead", "prompt_template": "Select technology stack for project: {feature_name}"}, {"name": "Project Setup", "role": "software-engineer", "order": 5, "required": true, "dependencies": [4], "skill": "software-engineer", "prompt_template": "Set up the project: {feature_name}"}, {"name": "Core Implementation", "role": "software-engineer", "order": 6, "required": true, "dependencies": [5], "skill": "software-engineer", "prompt_template": "Implement core functionality for: {feature_name}"}, {"name": "Test Development", "role": "testing-engineer", "order": 7, "required": true, "dependencies": [6], "skill": "testing-engineer", "prompt_template": "Develop tests for project: {feature_name}"}, {"name": "Documentation Creation", "role": "documentation-specialist", "order": 8, "required": true, "dependencies": [6], "skill": "documentation-specialist", "prompt_template": "Create documentation for project: {feature_name}"}, {"name": "Deployment Setup", "role": "devops-engineer", "order": 9, "required": true, "dependencies": [7, 8], "skill": "devops-engineer", "prompt_template": "Set up deployment for project: {feature_name}"}, {"name": "Security Validation", "role": "securi