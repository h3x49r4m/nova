{
  "name": "product-manager",
  "version": "1.0.0",
  "description": "Feature planning and prioritization",
  "type": "role",
  "capabilities": [
    "feature-planning",
    "prioritization",
    "user-story-creation",
    "backlog-management",
    "roadmap-planning",
    "stakeholder-management"
  ],
  "dependencies": [
    {
      "name": "client",
      "min_version": "1.0.0"
    }
  ],
  "settings": {
    "type": "role",
    "domains": {
      "product-management": {
        "supported": true
      },
      "agile-methodology": {
        "supported": true
      },
      "technical-implementation": {
        "supported": false,
        "reason": "Product Manager focuses on planning and prioritization, not implementation"
      }
    },
    "compatible_pipelines": [
      "team-pipeline-new-project",
      "team-pipeline-new-feature"
    ]
  }
}