{"name": "new-feature", "version": "1.0.0", "description": "Pipeline for adding features to existing projects", "stages": [{"name": "Requirements Gathering", "role": "client", "order": 1, "required": false, "conditions": {"skip_if": "requirements_provided"}, "skill": "client", "prompt_template": "Gather requirements for feature: {feature_name}"}, {"name": "Feature Planning", "role": "product-manager", "order": 2, "required": true, "dependencies": [1], "skill": "product-manager", "prompt_template": "Plan the feature: {feature_name} based on requirements from previous stage"}, {"name": "Sprint Planning", "role": "project-manager", "order": 3, "required": true, "dependencies": [2], "skill": "project-manager", "prompt_template": "Create sprint plan for feature: {feature_name}"}, {"name": "Design Creation", "role": "ui-ux-designer", "order": 4, "required": true, "dependencies": [3], "skill": "ui-ux-designer", "prompt_template": "Create UI/UX designs for feature: {feature_name}"}, {"name": "Architecture Review", "role": "tech-lead", "order": 5, "required": true, "dependencies": [4], "skill": "tech-lead", "prompt_template": "Review architecture impact for feature: {feature_name}"}, {"name": "Frontend Implementation", "role": "software-engineer", "order": 6, "required": true, "dependencies": [5], "parallel_group": "implementation", "skill": "software-engineer", "prompt_template": "Implement frontend for feature: {feature_name}"}, {"name": "Backend Implementation", "role": "software-engineer", "order": 7, "required": true, "dependencies": [5], "parallel_group": "implementation", "skill": "software-engineer", "prompt_template": "Implement backend for feature: {feature_name}"}, {"name": "Test Development", "role": "testing-engineer", "order": 8, "required": true, "dependencies": [6, 7], "skill": "testing-engineer", "prompt_template": "Develop tests for feature: {feature_name}"}, {"name": "Quality Validation", "role": "qa-engineer", "order": 9, "required": true, "dependencies": [8], "skill": "qa-engineer", "prompt_template": "Validate quality of feature: {feature_name}"}, {"name": "Security Review", "role": "security-engineer", "order": 10, "required": false, "dependencies": [9], "skill": "security-engineer", "prompt_template": "Review security for feature: {feature_name}"}, {"name": "Documentation Update", "role": "documentation-specialist", "order": 11, "required": false, "dependencies": [9], "skill": "documentation-specialist", "prompt_template": "Update documentation for feature: {feature_name}"}, {"name": "Deployment", "role": "devops-engineer", "order": 12, "required": true, "dependencies": [9, 10, 11], "skill": "devops-engineer", "prompt_template": "Deploy feature: {feature_name}"}], "quality_gates": {"test_coverage_threshold": 80, "max_bug_severity": "medium", "security_scan_required": true}, "notification_config": {"on_success": ["product-manager", "project-manager"], "on_failure": ["tech-lead", "project-manager"], "on_completion": ["product-manager", "client"]}}