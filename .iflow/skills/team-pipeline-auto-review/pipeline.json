{"name": "auto-review", "version": "1.0.0", "description": "Automated code review pipeline for PRs and commits", "stages": [{"name": "Lint Check", "role": "software-engineer", "order": 1, "required": true, "skill": "software-engineer", "prompt_template": "Run linting checks on the code"}, {"name": "Static Analysis", "role": "software-engineer", "order": 2, "required": true, "dependencies": [1], "skill": "software-engineer", "prompt_template": "Perform static analysis on the code"}, {"name": "Security Scanning", "role": "security-engineer", "order": 3, "required": true, "dependencies": [1], "parallel_group": "analysis", "skill": "security-engineer", "prompt_template": "Scan code for security vulnerabilities"}, {"name": "Test Validation", "role": "testing-engineer", "order": 4, "required": true, "dependencies": [1], "parallel_group": "analysis", "skill": "testing-engineer", "prompt_template": "Validate tests for the code"}, {"name": "Coverage Check", "role": "testing-engineer", "order": 5, "required": true, "dependencies": [4], "skill": "testing-engineer", "prompt_template": "Check test coverage for the code"}, {"name": "Code Quality Metrics", "role": "software-engineer", "order": 6, "required": true, "dependencies": [2, 3, 5], "skill": "software-engineer", "prompt_template": "Calculate code quality metrics"}, {"name": "Report Generation", "role": "documentation-specialist", "order": 7, "required": true, "dependencies": [6], "skill": "documentation-specialist", "prompt_template": "Generate code review report"}], "quality_gates": {"lint_errors_allowed": 0, "security_vulnerabilities_allowed": 0, "test_coverage_threshold": 80}, "notification_config": {"on_success": ["project-manager"], "on_failure": ["tech-lead", "software-engineer"], "on_completion": ["project-manager", "software-engineer"]}}