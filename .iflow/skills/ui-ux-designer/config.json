{
  "name": "ui-ux-designer",
  "version": "1.0.0",
  "description": "Design creation and user experience",
  "type": "role",
  "capabilities": [
    "ui-design",
    "ux-design",
    "prototyping",
    "wireframing",
    "design-systems",
    "accessibility-design",
    "responsive-design",
    "user-research"
  ],
  "dependencies": [
    {
      "name": "client",
      "min_version": "1.0.0"
    }
  ],
  "settings": {
    "type": "role",
    "domains": {
      "design": {
        "supported": true
      },
      "user-experience": {
        "supported": true
      },
      "development": {
        "supported": false,
        "reason": "UI/UX Designer focuses on design, not implementation"
      }
    },
    "compatible_pipelines": [
      "team-pipeline-new-project",
      "team-pipeline-new-feature"
    ]
  }
}