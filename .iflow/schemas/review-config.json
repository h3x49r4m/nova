{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://iflow.dev/schemas/review-config.json", "title": "Review Configuration Schema", "description": "Configuration schema for code review automation", "type": "object", "properties": {"tools": {"type": "array", "description": "Review tools configuration", "items": {"type": "object", "properties": {"name": {"type": "string", "enum": ["sonarqube", "snyk", "eslint", "pylint", "flake8", "mypy"]}, "enabled": {"type": "boolean"}, "config": {"type": "object"}}, "required": ["name", "enabled"]}}, "rules": {"type": "array", "description": "Review rules", "items": {"type": "object", "properties": {"id": {"type": "string"}, "name": {"type": "string"}, "category": {"type": "string", "enum": ["code_quality", "security", "performance", "maintainability", "style", "documentation", "testing", "complexity", "duplication", "naming"]}, "severity": {"type": "string", "enum": ["info", "warning", "error", "critical", "blocker"]}, "enabled": {"type": "boolean"}, "blocking": {"type": "boolean"}, "parameters": {"type": "object"}}, "required": ["id", "name", "category", "severity"]}}, "quality_gates": {"type": "object", "description": "Quality gate thresholds", "properties": {"max_critical": {"type": "integer", "minimum": 0}, "max_high": {"type": "integer", "minimum": 0}, "max_medium": {"type": "integer", "minimum": 0}, "min_coverage": {"type": "number", "minimum": 0, "maximum": 100}, "max_duplication": {"type": "number", "minimum": 0, "maximum": 100}}}, "notifications": {"type": "object", "description": "Notification settings", "properties": "enabled": {"type": "boolean"}, "channels": {"type": "array", "items": {"type": "string", "enum": ["email", "slack", "webhook", "cli", "file"]}}, "triggers": {"type": "array", "items": {"type": "string", "enum": ["review_started", "review_completed", "review_failed", "critical_finding", "high_severity", "quality_gate_failed", "blocking_rule_failed", "tool_error"]}}}}, "required": ["tools", "rules"]}