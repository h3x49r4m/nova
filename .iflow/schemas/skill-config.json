{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://iflow.dev/schemas/skill-config.json", "title": "Skill Configuration Schema", "description": "Configuration schema for iFlow skills", "type": "object", "properties": {"name": {"type": "string", "description": "Name of the skill"}, "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$", "description": "Semantic version of the skill"}, "description": {"type": "string", "description": "Description of the skill"}, "capabilities": {"type": "array", "description": "List of capabilities provided by the skill", "items": {"type": "string"}}, "dependencies": {"type": "array", "description": "List of skill dependencies", "items": {"type": "object", "properties": {"name": {"type": "string"}, "min_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"}}, "required": ["name"]}}, "workflows": {"type": "array", "description": "Available workflows", "items": {"type": "object", "properties": {"name": {"type": "string"}, "description": {"type": "string"}, "steps": {"type": "array", "items": {"type": "object"}}}, "required": ["name"]}}, "settings": {"type": "object", "description": "Skill-specific settings", "additionalProperties": true}}, "required": ["name", "version"]}