{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://iflow.dev/schemas/logging-config.json", "title": "Logging Configuration Schema", "description": "Configuration schema for structured logging", "type": "object", "properties": "level": {"type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"], "description": "Minimum log level"}, "format": {"type": "string", "enum": ["json", "text", "concise"], "description": "Log format"}, "handlers": {"type": "array", "description": "Log handlers", "items": {"type": "object", "properties": {"type": {"type": "string", "enum": ["console", "file", "syslog"]}, "level": {"type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]}, "format": {"type": "string", "enum": ["json", "text", "concise"]}, "file": {"type": "string", "description": "File path for file handler"}, "rotation": {"type": "object", "properties": {"enabled": {"type": "boolean"}, "max_size_mb": {"type": "integer", "minimum": 1}, "max_files": {"type": "integer", "minimum": 1}}}}}}, "filters": {"type": "array", "description": "Log filters", "items": {"type": "object", "properties": {"name": {"type": "string"}, "pattern": {"type": "string"}, "level": {"type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]}, "exclude": {"type": "boolean"}}}}, "structured": {"type": "boolean", "description": "Whether to use structured logging"}, "include_timestamp": {"type": "boolean", "description": "Whether to include timestamps"}, "include_context": {"type": "boolean", "description": "Whether to include context information"}}