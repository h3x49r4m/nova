{"$schema": "http://json-schema.org/draft-07/schema#", "title": "iFlow Skill Configuration Schema", "description": "Standard schema for iFlow CLI skill configuration files", "type": "object", "required": ["name", "version", "description", "type", "capabilities", "dependencies", "settings"], "properties": {"name": {"type": "string", "description": "Skill identifier name (kebab-case)", "pattern": "^[a-z0-9-]+$"}, "version": {"type": "string", "description": "Semantic version (major.minor.patch)", "pattern": "^\\d+\\.\\d+\\.\\d+$"}, "description": {"type": "string", "description": "Brief description of the skill"}, "type": {"type": "string", "description": "Type of skill", "enum": ["role", "pipeline", "workflow", "tool"]}, "capabilities": {"type": "array", "description": "List of capabilities provided by this skill", "items": {"type": "string"}, "minItems": 1}, "dependencies": {"type": "array", "description": "List of skill dependencies", "items": {"type": "object", "properties": {"name": {"type": "string"}, "min_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"}}, "required": ["name"]}}, "settings": {"type": "object", "description": "Skill-specific settings", "properties": {"domains": {"type": "object", "description": "Domain support configuration", "additionalProperties": {"type": "object", "properties": {"supported": {"type": "boolean"}, "reason": {"type": "string"}}}}, "compatible_pipelines": {"type": "array", "description": "List of compatible pipeline names", "items": {"type": "string"}}}}}}