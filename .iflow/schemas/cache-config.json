{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://iflow.dev/schemas/cache-config.json", "title": "Cache Configuration Schema", "description": "Configuration schema for cache management", "type": "object", "properties": {"backend": {"type": "string", "enum": ["memory", "file", "persistent"], "description": "Cache backend type"}, "max_size_mb": {"type": "integer", "minimum": 1, "description": "Maximum cache size in MB"}, "strategy": {"type": "string", "enum": ["lru", "lfu", "fifo", "ttl"], "description": "Cache eviction strategy"}, "default_ttl": {"type": "integer", "minimum": 0, "description": "Default time-to-live in seconds"}, "cache_dir": {"type": "string", "description": "Cache directory for file-based backends"}, "entries": {"type": "object", "description": "Cache entry configurations", "additionalProperties": {"type": "object", "properties": {"enabled": {"type": "boolean"}, "ttl": {"type": "integer", "minimum": 0}, "prefix": {"type": "string"}}}}}, "required": ["backend"]}