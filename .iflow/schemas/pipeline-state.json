{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://iflow.cli/schemas/pipeline-state.json", "title": "Pipeline State Schema", "description": "Schema for validating pipeline state files", "type": "object", "required": ["pipeline_name", "feature_name", "status", "stages"], "properties": {"pipeline_name": {"type": "string", "minLength": 1, "description": "Name of the pipeline"}, "feature_name": {"type": "string", "minLength": 1, "description": "Name of the feature or work item"}, "status": {"type": "string", "enum": ["pending", "running", "paused", "completed", "failed", "cancelled"], "description": "Current pipeline status"}, "started_at": {"type": "string", "format": "date-time", "description": "When the pipeline started"}, "completed_at": {"type": "string", "format": "date-time", "description": "When the pipeline completed"}, "stages": {"type": "array", "items": {"type": "object", "required": ["name", "role", "order", "status"], "properties": {"name": {"type": "string", "minLength": 1, "description": "Stage name"}, "role": {"type": "string", "minLength": 1, "description": "Role responsible for this stage"}, "order": {"type": "integer", "minimum": 1, "description": "Stage execution order"}, "status": {"type": "string", "enum": ["pending", "running", "completed", "failed", "skipped", "blocked"], "description": "Stage status"}, "required": {"type": "boolean", "default": true, "description": "Whether this stage is required"}, "dependencies": {"type": "array", "items": {"type": "integer", "minimum": 1}, "description": "List of stage orders this stage depends on"}, "conditions": {"type": "object", "description": "Conditions for stage execution"}, "parallel_group": {"type": "string", "description": "Parallel execution group identifier"}, "started_at": {"type": "string", "format": "date-time", "description": "When this stage started"}, "completed_at": {"type": "string", "format": "date-time", "description": "When this stage completed"}, "error": {"type": "string", "description": "Error message if stage failed"}, "result": {"type": "object", "description": "Stage execution result"}, "retries": {"type": "integer", "minimum": 0, "default": 0, "description": "Number of retry attempts"}, "max_retries": {"type": "integer", "minimum": 0, "default": 3, "description": "Maximum retry attempts allowed"}}}, "description": "List of pipeline stages"}, "current_stage": {"type": "integer", "minimum": 0, "default": 0, "description": "Current stage index"}, "metadata": {"type": "object", "description": "Additional pipeline metadata"}, "issues": {"type": "array", "items": {"type": "object", "required": ["severity", "title"], "properties": {"severity": {"type": "string", "enum": ["low", "medium", "high", "critical"], "description": "Issue severity"}, "title": {"type": "string", "minLength": 1, "description": "Issue title"}, "description": {"type": "string", "description": "Issue description"}, "assigned_to": {"type": "string", "description": "Who is assigned to fix this issue"}, "status": {"type": "string", "description": "Issue status"}, "retry_count": {"type": "integer", "minimum": 0, "description": "Number of retry attempts"}}}, "description": "List of issues encountered"}, "created_at": {"type": "string", "format": "date-time", "description": "When the pipeline state was created"}, "updated_at": {"type": "string", "format": "date-time", "description": "When the pipeline state was last updated"}, "_metadata": {"type": "object", "description": "Internal metadata"}, "_version": {"type": "string", "description": "State schema version"}}}