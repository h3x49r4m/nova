{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://iflow.cli/schemas/pipeline-config.json", "title": "Pipeline Configuration Schema", "description": "Schema for validating pipeline configuration files", "type": "object", "required": ["name", "version", "type", "description", "stages"], "properties": {"name": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9-]+$", "description": "Pipeline name (lowercase, alphanumeric, hyphens)"}, "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "description": "Semantic version (major.minor.patch)"}, "type": {"type": "string", "enum": ["pipeline"], "description": "Configuration type"}, "description": {"type": "string", "minLength": 1, "description": "Pipeline description"}, "stages": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name", "role", "order", "status"], "properties": {"name": {"type": "string", "minLength": 1, "description": "Stage name"}, "role": {"type": "string", "minLength": 1, "description": "Role responsible for this stage"}, "skill": {"type": "string", "minLength": 1, "description": "Skill to invoke for this stage"}, "prompt_template": {"type": "string", "minLength": 1, "description": "Prompt template for skill invocation"}, "order": {"type": "integer", "minimum": 1, "description": "Stage execution order"}, "status": {"type": "string", "enum": ["pending", "running", "completed", "failed", "skipped", "blocked"], "description": "Stage status"}, "required": {"type": "boolean", "default": true, "description": "Whether this stage is required"}, "dependencies": {"type": "array", "items": {"type": "integer", "minimum": 1}, "description": "List of stage orders this stage depends on"}, "conditions": {"type": "object", "description": "Conditions for stage execution"}, "parallel_group": {"type": "string", "description": "Parallel execution group identifier"}, "started_at": {"type": "string", "format": "date-time", "description": "When this stage started"}, "completed_at": {"type": "string", "format": "date-time", "description": "When this stage completed"}, "error": {"type": "string", "description": "Error message if stage failed"}, "result": {"type": "object", "description": "Stage execution result"}, "retries": {"type": "integer", "minimum": 0, "default": 0, "description": "Number of retry attempts"}, "max_retries": {"type": "integer", "minimum": 0, "default": 3, "description": "Maximum retry attempts allowed"}}, "description": "List of pipeline stages"}, "quality_gates": {"type": "object", "properties": {"test_coverage_threshold": {"type": "integer", "minimum": 0, "maximum": 100, "description": "Minimum test coverage percentage"}, "max_bug_severity": {"type": "string", "enum": ["low", "medium", "high", "critical"], "description": "Maximum allowed bug severity"}, "security_scan_required": {"type": "boolean", "description": "Whether security scan is required"}, "documentation_required": {"type": "boolean", "description": "Whether documentation is required"}, "lint_errors_allowed": {"type": "integer", "minimum": 0, "description": "Maximum allowed lint errors"}, "security_vulnerabilities_allowed": {"type": "integer", "minimum": 0, "description": "Maximum allowed security vulnerabilities"}, "regression_test_required": {"type": "boolean", "description": "Whether regression test is required"}}, "description": "Quality gate configurations"}, "notification_config": {"type": "object", "properties": {"on_success": {"type": "array", "items": {"type": "string"}, "description": "Roles to notify on success"}, "on_failure": {"type": "array", "items": {"type": "string"}, "description": "Roles to notify on failure"}, "on_completion": {"type": "array", "items": {"type": "string"}, "description": "Roles to notify on completion"}}, "description": "Notification configuration"}}