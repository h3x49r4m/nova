{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://iflow.dev/schemas/notification-config.json", "title": "Notification Configuration Schema", "description": "Configuration schema for notification system", "type": "object", "properties": {"channels": {"type": "array", "description": "Notification channel configurations", "items": {"type": "object", "properties": {"channel": {"type": "string", "enum": ["email", "slack", "webhook", "cli", "file"]}, "enabled": {"type": "boolean"}, "triggers": {"type": "array", "items": {"type": "string", "enum": ["review_started", "review_completed", "review_failed", "critical_finding", "high_severity", "quality_gate_failed", "blocking_rule_failed", "tool_error"]}}, "min_severity": {"type": "string", "enum": ["info", "success", "warning", "error", "critical"]}, "config": {"type": "object", "description": "Channel-specific configuration"}}, "required": ["channel", "enabled"]}}, "global_settings": {"type": "object", "properties": {"rate_limit": {"type": "integer", "minimum": 1, "description": "Maximum notifications per minute"}, "batch_notifications": {"type": "boolean", "description": "Whether to batch notifications"}, "batch_interval": {"type": "integer", "minimum": 1, "description": "Batch interval in seconds"}}}}, "required": ["channels"]}